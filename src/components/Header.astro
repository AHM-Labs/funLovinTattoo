---
import Logo from "./Logo.astro";
import Monogram from "./Monogram.astro";
---
<header class="w-full border-b border-flt-border sticky top-0 z-[100] bg-flt-bg/90 backdrop-blur-xl">
  <div class="max-w-7xl mx-auto flex justify-between items-center py-8 px-4 sm:px-8 lg:px-12">
    <div class="relative z-50 flex items-center gap-4">
      <a href="/" class="block w-10 text-flt-cream hover:text-flt-ivory transition-colors duration-300">
        <Monogram class="w-full h-auto" />
      </a>
      <div class="h-8 w-px bg-flt-border"></div>
      <a href="/" class="block w-36 text-flt-ivory hover:text-flt-cream transition-colors duration-300">
        <Logo class="w-full h-auto" />
      </a>
    </div>
    
    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-10 font-label uppercase tracking-[0.2em] text-[10px]">
      <a href="/" class="text-flt-muted hover:text-flt-ivory transition-colors duration-300">Home</a>
      <div class="relative group py-2">
        <a href="/mobile-services" class="text-flt-muted hover:text-flt-cream transition-colors duration-300 flex items-center gap-2">
          Mobile Tattoo <span class="text-[8px] opacity-40 translate-y-px">▼</span>
        </a>
        <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 min-w-(--spacing-48)">
          <div class="bg-flt-bg border border-flt-border p-5 space-y-4 shadow-[0_20px_50px_rgba(0,0,0,0.9)] backdrop-blur-xl">
            <a href="/weddings" class="block text-flt-muted hover:text-flt-cream transition-colors tracking-widest">Wedding</a>
            <a href="/corporate" class="block text-flt-muted hover:text-flt-cream transition-colors tracking-widest">Corporate</a>
            <a href="/events" class="block text-flt-muted hover:text-flt-cream transition-colors tracking-widest">Events</a>
            <div class="h-px bg-flt-border my-2"></div>
            <a href="/mobile-services" class="block text-[9px] text-flt-cream/60 hover:text-flt-cream transition-colors tracking-[0.2em]">All Mobile &rarr;</a>
          </div>
        </div>
      </div>
      <a href="/studio" class="text-flt-muted hover:text-flt-cream transition-colors duration-300">Studio</a>
      <a href="/artists" class="text-flt-muted hover:text-flt-cream transition-colors duration-300">Artists</a>
      <a href="/gallery" class="text-flt-muted hover:text-flt-cream transition-colors duration-300">Gallery</a>
      <a href="/news" class="text-flt-muted hover:text-flt-cream transition-colors duration-300">Journal</a>
      <a href="/book" class="text-flt-muted hover:text-flt-cream transition-colors duration-300">Gift Cards</a>
    </nav>
  
    <div class="flex items-center gap-6">
      <a href="/book" class="hidden sm:inline-block bg-flt-cream text-black px-8 py-3 font-label text-[10px] uppercase tracking-[0.2em] hover:bg-white transition-all duration-300 font-bold shadow-lg">
        Enquire
      </a>
      
      <!-- Burger Button -->
      <button id="menu-toggle" class="md:hidden flex flex-col gap-1.5 p-2 relative z-[200]" aria-label="Toggle Menu">
        <span class="w-6 h-0.5 bg-flt-cream transition-all duration-300 burger-line"></span>
        <span class="w-6 h-0.5 bg-flt-cream transition-all duration-300 burger-line"></span>
        <span class="w-6 h-0.5 bg-flt-cream transition-all duration-300 burger-line"></span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Menu Overlay -->
<div id="mobile-menu" class="fixed inset-0 bg-flt-bg/98 backdrop-blur-2xl z-90 flex flex-col items-center pointer-events-none opacity-0 overflow-y-auto pt-32 pb-12">
  <nav class="flex flex-col items-center gap-6 text-center px-6 relative z-10 w-full">
    <a href="/" class="mobile-link font-headline italic text-2xl ivory-text opacity-0 block leading-tight">Home</a>
    <div class="mobile-link flex flex-col items-center gap-3 opacity-0 pt-2">
      <a href="/mobile-services" class="font-label text-[9px] uppercase tracking-[0.4em] text-flt-muted/40 mb-2">Mobile Tattoo</a>
      <a href="/weddings" class="font-headline italic text-xl ivory-text">Wedding</a>
      <a href="/corporate" class="font-headline italic text-xl ivory-text">Corporate</a>
      <a href="/events" class="font-headline italic text-xl ivory-text">Events</a>
    </div>
    <a href="/studio" class="mobile-link font-headline italic text-2xl ivory-text opacity-0 leading-tight">Studio</a>
    <a href="/artists" class="mobile-link font-headline italic text-2xl ivory-text opacity-0 leading-tight">Artists</a>
    <a href="/gallery" class="mobile-link font-headline italic text-2xl ivory-text opacity-0 leading-tight">Gallery</a>
    <a href="/news" class="mobile-link font-headline italic text-2xl ivory-text opacity-0 leading-tight">Journal</a>
    <a href="/book" class="mobile-link font-headline italic text-2xl ivory-text opacity-0 leading-tight">Gift Cards</a>
    <div class="mt-8 opacity-0 mobile-link">
      <a href="/book" class="bg-flt-cream text-black px-12 py-5 font-label text-xs uppercase tracking-[0.2em] font-bold shadow-xl">
        Enquire Now
      </a>
    </div>
  </nav>
</div>


<script>
  import { gsap } from 'gsap';

  const toggle = document.querySelector('#menu-toggle');
  const menu = document.querySelector('#mobile-menu');
  const links = document.querySelectorAll('.mobile-link');
  const lines = document.querySelectorAll('.burger-line');
  let isOpen = false;

  const tl = gsap.timeline({ paused: true });

  tl.to(menu, { 
    opacity: 1, 
    pointerEvents: 'auto', 
    duration: 0.4, 
    ease: 'power2.inOut' 
  });

  tl.to(links, {
    opacity: 1,
    y: 0,
    stagger: 0.05,
    duration: 0.4,
    ease: 'power2.out',
    startAt: { y: 15 }
  }, "-=0.2");

  // Burger animation
  const burgerTl = gsap.timeline({ paused: true });
  burgerTl.to(lines[0], { y: 8, rotate: 45, duration: 0.3, backgroundColor: '#d4ba8c' });
  burgerTl.to(lines[1], { opacity: 0, duration: 0.1 }, "-=0.3");
  burgerTl.to(lines[2], { y: -8, rotate: -45, duration: 0.3, backgroundColor: '#d4ba8c' }, "-=0.3");

  toggle?.addEventListener('click', () => {
    isOpen = !isOpen;
    if (isOpen) {
      tl.play();
      burgerTl.play();
      document.body.style.overflow = 'hidden';
    } else {
      tl.reverse();
      burgerTl.reverse();
      document.body.style.overflow = '';
    }
  });

  // Close menu on overlay click
  menu?.addEventListener('click', (e) => {
    if (e.target === menu) {
      isOpen = false;
      tl.reverse();
      burgerTl.reverse();
      document.body.style.overflow = '';
    }
  });

  // Close menu on link click
  links.forEach(link => {
    link.addEventListener('click', () => {
      isOpen = false;
      tl.reverse();
      burgerTl.reverse();
      document.body.style.overflow = '';
    });
  });
</script>
