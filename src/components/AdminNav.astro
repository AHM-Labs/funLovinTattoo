---
import { canManageTeam, canManageGlobalBlog, canManagePricing } from "../lib/permissions";

const { currentPath, userRole } = Astro.props;

const navItems = [
    { name: 'Dashboard', href: '/admin' },
    { name: 'Enquiries', href: '/admin/bookings' },
    { name: 'Gift Cards', href: '/admin/gift-cards' },
    { name: 'Journal', href: '/admin/journal', visible: canManageGlobalBlog(userRole) },
    { name: 'Gallery', href: '/admin/gallery' },
    { name: 'Pricing', href: '/admin/pricing', visible: canManagePricing(userRole) },
    { name: 'Team', href: '/admin/team', visible: canManageTeam(userRole) },
    { name: 'My Profile', href: '/admin/profile' },
].filter(item => item.visible !== false);

const isActive = (path: string) => {
    if (path === '/admin') return currentPath === '/admin';
    return currentPath.startsWith(path);
};
---
<nav class="border-b border-flt-border bg-flt-bg/50 backdrop-blur-xl sticky top-0 z-40 overflow-x-auto whitespace-nowrap hide-scrollbar">
    <div class="max-w-7xl mx-auto px-4 sm:px-8 lg:px-12 flex items-center h-16 gap-8">
        {navItems.map(item => (
            <a 
                href={item.href}
                class={`font-label text-[10px] uppercase tracking-widest transition-all h-full flex items-center border-b-2 hover:text-flt-cream ${isActive(item.href) ? 'border-flt-cream text-flt-cream' : 'border-transparent text-flt-muted/40'}`}
            >
                {item.name}
            </a>
        ))}
    </div>
</nav>

<style>
    .hide-scrollbar::-webkit-scrollbar {
        display: none;
    }
    .hide-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
</style>
