---
const { currentPath } = Astro.props;

const navItems = [
    { name: 'Dashboard', href: '/admin' },
    { name: 'Inquiries', href: '/admin/bookings' },
    { name: 'Journal', href: '/admin/journal' },
    { name: 'Gallery', href: '/admin/gallery' },
    { name: 'Team', href: '/admin/team' },
];

const isActive = (path: string) => {
    if (path === '/admin') return currentPath === '/admin';
    return currentPath.startsWith(path);
};
---

<div class="w-full bg-black/40 backdrop-blur-md border-b border-flt-ivory-border/10 sticky top-[95px] z-40">
    <div class="max-w-7xl mx-auto px-4 sm:px-8 lg:px-12">
        <nav class="flex items-center gap-8 overflow-x-auto no-scrollbar py-4">
            {navItems.map(item => (
                <a 
                    href={item.href}
                    class={`font-label text-[9px] uppercase tracking-[0.2em] whitespace-nowrap transition-all duration-300 ${isActive(item.href) ? 'text-flt-cream border-b border-flt-cream/50 pb-1' : 'text-flt-muted hover:text-white'}`}
                >
                    {item.name}
                </a>
            ))}
        </nav>
    </div>
</div>

<style>
    .no-scrollbar::-webkit-scrollbar {
        display: none;
    }
    .no-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
</style>
