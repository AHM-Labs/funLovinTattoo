---
import { canManageTeam, canManageGlobalBlog } from "../lib/permissions";
import { canManageTeam, canManageGlobalBlog, canManagePricing } from "../lib/permissions";

const { currentPath, userRole } = Astro.props;

const navItems = [
    { name: 'Dashboard', href: '/admin' },
    { name: 'Enquiries', href: '/admin/bookings' },
    { name: 'Journal', href: '/admin/journal', visible: canManageGlobalBlog(userRole) },
    { name: 'Gallery', href: '/admin/gallery' },
    { name: 'Pricing', href: '/admin/pricing', visible: canManagePricing(userRole) },
    { name: 'Team', href: '/admin/team', visible: canManageTeam(userRole) },
    { name: 'My Profile', href: '/admin/profile' },
].filter(item => item.visible !== false);

const isActive = (path: string) => {
    if (path === '/admin') return currentPath === '/admin';
    return currentPath.startsWith(path);
};
---

<div class="w-full bg-flt-bg/40 backdrop-blur-md border-b border-flt-border sticky top-[95px] z-40">
    <div class="max-w-7xl mx-auto px-4 sm:px-8 lg:px-12">
        <nav class="flex items-center gap-8 overflow-x-auto no-scrollbar py-4 font-label text-[9px] uppercase tracking-[0.2em]">
            {navItems.map(item => (
                <a 
                    href={item.href}
                    class={`whitespace-nowrap transition-all duration-300 ${isActive(item.href) ? 'text-flt-cream border-b border-flt-cream/50 pb-1' : 'text-flt-muted hover:text-flt-cream'}`}
                >
                    {item.name}
                </a>
            ))}
        </nav>
    </div>
</div>

<style>
    .no-scrollbar::-webkit-scrollbar {
        display: none;
    }
    .no-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
</style>
