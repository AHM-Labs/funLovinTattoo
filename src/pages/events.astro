---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Bespoke Events | Private & Editorial Tattoos">
  <div class="max-w-7xl mx-auto px-4 sm:px-8 lg:px-12 py-24">
    <div class="text-center mb-32">
      <span class="font-label text-[10px] uppercase tracking-[0.4em] text-flt-muted mb-6 inline-block">Exclusive Gatherings</span>
      <h1 class="font-headline text-7xl md:text-[9.5rem] italic tracking-tighter ivory-text font-black uppercase leading-[0.8]">Art <br/> & Occasion.</h1>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-20 items-center mb-32">
      <div class="lg:col-span-5 order-2 lg:order-1 space-y-12">
        <h2 class="font-headline text-5xl italic ivory-text leading-tight uppercase">Curated Live <br/> Tattooing.</h2>
        <p class="font-body text-xl text-flt-muted leading-relaxed">
          Elevate your private event with the presence of professional artistry. From milestone celebrations to exclusive editorial parties, our mobile studio brings a layer of permanence and sophistication to any occasion.
        </p>
        <div class="grid grid-cols-2 gap-8 pt-8 border-t border-flt-ivory-border/20">
          <div>
             <p class="font-headline text-3xl ivory-text italic mb-2">Elite</p>
             <p class="font-label text-[9px] uppercase tracking-widest text-flt-muted">LEVEL ARTISTRY</p>
          </div>
          <div>
            <p class="font-headline text-3xl ivory-text italic mb-2">Unforgettable</p>
            <p class="font-label text-[9px] uppercase tracking-widest text-flt-muted">EXPERIENCE</p>
          </div>
        </div>
      </div>
      <div class="lg:col-span-7 order-1 lg:order-2">
        <div class="aspect-video bg-flt-border/5 border-premium overflow-hidden group">
          <img 
            src="https://images.unsplash.com/photo-1590247813693-5541d1c609fd?auto=format&fit=crop&q=80&w=1200" 
            alt="Event Activation" 
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-[4s]" 
          />
        </div>
      </div>
    </div>

    <section class="py-24 bg-[#0d0d0d] border border-flt-ivory-border/10 p-12 lg:p-20 text-center">
       <span class="font-label text-[10px] uppercase tracking-[0.4rem] text-flt-muted block mb-12">The Mobile Standard</span>
       <h3 class="font-headline text-5xl md:text-7xl italic ivory-text uppercase tracking-tighter mb-12">Luxury Redefined.</h3>
       <p class="font-body text-lg text-flt-muted/70 max-w-2xl mx-auto leading-relaxed">
         Our mobile studio isn't just a workspace—it's an extension of our professional environment, meticulously maintained to provide the highest standard of care and artistry in any setting.
       </p>
       <div class="mt-16 pt-12 border-t border-flt-ivory-border/10">
          <a href="/book" class="bg-flt-cream text-black px-12 py-6 font-label text-[11px] uppercase tracking-widest font-bold hover:bg-white transition-all">Book Your Event</a>
       </div>
    </section>
  </div>
</Layout>
