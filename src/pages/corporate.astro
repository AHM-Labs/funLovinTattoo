---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Corporate & Events | Brand Activations">
  <div class="max-w-7xl mx-auto px-4 sm:px-8 lg:px-12 py-24">
    <div class="text-center mb-32">
      <span class="font-label text-[10px] uppercase tracking-[0.4em] text-flt-muted mb-6 inline-block">Brand Activations</span>
      <h1 class="font-headline text-7xl md:text-[9.5rem] italic tracking-tighter ivory-text font-black uppercase leading-[0.8]">Impact <br/> & Identity.</h1>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-20 items-center mb-32">
      <div class="lg:col-span-5 order-2 lg:order-1 space-y-12">
        <h2 class="font-headline text-5xl italic ivory-text leading-tight uppercase">High-Impact <br/> Activations.</h2>
        <p class="font-body text-xl text-flt-muted leading-relaxed">
          Transform your brand event with a luxury mobile tattoo experience. We specialize in upscale corporate gatherings, fashion launches, and luxury brand activations that leave a truly permanent impression.
        </p>
        <div class="grid grid-cols-2 gap-8 pt-8 border-t border-flt-ivory-border/20">
          <div>
             <p class="font-headline text-3xl ivory-text italic mb-2">100%</p>
             <p class="font-label text-[9px] uppercase tracking-widest text-flt-muted">ENGAGEMENT</p>
          </div>
          <div>
            <p class="font-headline text-3xl ivory-text italic mb-2">Infinite</p>
            <p class="font-label text-[9px] uppercase tracking-widest text-flt-muted">IMPRESSIONS</p>
          </div>
        </div>
      </div>
      <div class="lg:col-span-7 order-1 lg:order-2">
        <div class="aspect-video bg-flt-border/5 border-premium overflow-hidden group">
          <img 
            src="https://images.unsplash.com/photo-1598371839696-5c5bb00bdc28?auto=format&fit=crop&q=80&w=1200" 
            alt="Corporate Activation" 
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-[4s] grayscale brightness-75 hover:brightness-100" 
          />
        </div>
      </div>
    </div>

    <section class="py-24 bg-[#0d0d0d] border border-flt-ivory-border/10 p-12 lg:p-20">
      <div class="max-w-4xl mx-auto text-center space-y-12">
        <span class="font-label text-[10px] uppercase tracking-[0.4rem] text-flt-muted block">The Mobile Studio</span>
        <h3 class="font-headline text-4xl md:text-6xl italic ivory-text uppercase tracking-tighter">Bespoke van conversion. <br/> Unlimited mobility.</h3>
        <p class="font-body text-lg text-flt-muted/70">Our customized luxury transit studio allows us to setup virtually anywhere—from warehouse parties to remote forest festivals—maintaining absolute sterile integrity and premium aesthetics.</p>
        <div class="pt-12">
           <a href="/mobile-services" class="font-label text-[11px] uppercase tracking-widest ivory-text border-b border-flt-ivory-border/50 pb-2 hover:border-white transition-all">Explore Mobile Services &rarr;</a>
        </div>
      </div>
    </section>

    <PricingSection 
        type="mobile" 
        categoryName="Corporate & Events" 
        title="Event Pricing." 
        description="Scalable mobile tattoo activations for brands, corporations, and luxury events. Our pricing is reflective of the premium logistics and sterile integrity required for high-capacity activations."
    />

    <div class="mt-32 grid grid-cols-1 md:grid-cols-2 gap-px bg-flt-ivory-border/10">
      <div class="bg-flt-bg p-20 space-y-8">
        <h4 class="font-headline text-4xl italic ivory-text uppercase">Corporate</h4>
        <p class="font-body text-flt-muted opacity-60">Team building, milestones, and office celebrations with a unique edge.</p>
        <a href="/book?type=corporate" class="inline-block font-label text-[10px] uppercase tracking-widest text-flt-cream border border-flt-cream/30 px-10 py-5 hover:bg-flt-cream hover:text-black transition-all">Contact Us</a>
      </div>
      <div class="bg-[#111] p-20 space-y-8">
        <h4 class="font-headline text-4xl italic ivory-text uppercase">Events</h4>
        <p class="font-body text-flt-muted opacity-60">Fashion shows, festivals, and high-end private gatherings globally.</p>
        <a href="/book?type=event" class="inline-block font-label text-[10px] uppercase tracking-widest text-flt-cream border border-flt-cream/30 px-10 py-5 hover:bg-flt-cream hover:text-black transition-all">Contact Us</a>
      </div>
    </div>
  </div>
</Layout>
