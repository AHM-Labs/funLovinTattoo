---
export const prerender = false;
import Layout from "../layouts/Layout.astro";
import { db } from "../db";
import { settings } from "../db/schema";
import { eq } from "drizzle-orm";

const locationSetting = await db
  .select()
  .from(settings)
  .where(eq(settings.key, "van_location"));
const currentVanLocation = locationSetting[0]?.value || "On Location Globally";
---

<Layout title="Fun Lovin Tattoo | Professional Artistry">
  <section
    class="relative min-h-[90vh] flex flex-col justify-center overflow-hidden border-b border-flt-border ivory-gradient"
  >
    <div
      class="absolute inset-0 bg-[url('/noise.png')] opacity-15 pointer-events-none mix-blend-overlay"
    >
    </div>
    <div
      class="max-w-7xl mx-auto px-4 sm:px-8 lg:px-12 w-full grid grid-cols-1 lg:grid-cols-12 gap-12 items-center py-24"
    >
      <div class="lg:col-span-8 z-20">
        <span
          class="inline-block font-label text-[10px] uppercase tracking-[0.4em] mb-12 text-flt-muted"
          >EST. 2007 — PROFESSIONAL TATTOO ARTISTRY</span
        >
        <h1
          class="font-headline text-fluid-h1 leading-[0.85] italic tracking-tighter mb-12 cream-text uppercase"
        >
          Mobile <br />
          <span class="ml-5 md:ml-24">Artistry,</span>
          <br />
          <span class="italic stroke-text text-transparent"
            >Bespoke Studio.</span
          >
        </h1>
        <div class="max-w-md ml-4 md:ml-32 space-y-8">
          <p class="font-body text-lg text-flt-muted leading-relaxed">
            Luxury tattooing, wherever you are. Our custom-converted private
            mobile studio brings elite artistry to your doorstep, wedding, or
            multi-day event.
          </p>
          <div class="flex flex-wrap gap-8 items-center pt-4">
            <a
              href="/book"
              class="bg-flt-cream text-black px-12 py-6 font-label text-[11px] uppercase tracking-[0.2em] transition-all hover:bg-white font-bold shadow-xl"
            >
              Book Event
            </a>
            <a
              href="/news"
              class="group flex items-center gap-4 py-5 font-label text-[11px] uppercase tracking-[0.2em]"
            >
              <span
                class="border-b border-flt-cream/30 group-hover:border-flt-cream pb-1 transition-all cream-text"
                >The Journal</span
              >
              <span class="text-xs cream-text">&nearr;</span>
            </a>
          </div>
        </div>
      </div>
      <div class="lg:col-span-4 relative mt-20 lg:mt-0">
        <div
          class="aspect-[3/4] bg-flt-bg/5 relative blob-mask overflow-hidden contrast-125 transition-all duration-1000 border-premium group"
        >
          <img
            src="/assets/mobile_van_hero.png"
            alt="Fun Lovin Tattoo Mobile Studio"
            class="w-full h-full object-cover scale-110 group-hover:scale-100 transition-all duration-[3000ms]"
          />
        </div>
        <div
          class="absolute -bottom-8 -left-12 z-30 p-8 bg-flt-bg border-premium hidden lg:block backdrop-blur-md shadow-2xl"
        >
          <p
            class="font-label text-[8px] uppercase tracking-widest text-flt-muted mb-2"
          >
            MOBILE STATUS
          </p>
          <p
            class="font-headline italic text-2xl cream-text leading-tight uppercase tracking-tighter"
          >
            {currentVanLocation}
          </p>
        </div>
      </div>
    </div>

    <div
      class="absolute right-[-5%] top-1/2 -translate-y-1/2 rotate-90 origin-right hidden xl:block pointer-events-none"
    >
      <span
        class="font-headline text-[12rem] text-transparent stroke-text opacity-10 uppercase tracking-tighter whitespace-nowrap"
        >FUN LOVIN TATTOO</span
      >
    </div>
  </section>

  <!-- Section 2: The Mobile Sanctuary -->
  <section class="border-t border-flt-border bg-[#0d0d0d] relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-8 lg:px-12 py-32 sm:py-48">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-24 items-center">
        <div class="z-10 order-2 lg:order-1">
          <span class="font-label text-[9px] uppercase tracking-[0.4rem] text-flt-muted mb-6 block">The Studio on Wheels</span>
          <h2 class="font-headline text-fluid-h2 italic tracking-tighter mb-10 cream-text uppercase leading-[0.9]">
            The Mobile <br/> Sanctuary.
          </h2>
          <div class="space-y-8 max-w-xl">
            <p class="font-body text-xl text-flt-muted leading-relaxed">
              A masterclass in bespoke luxury. Our custom-converted studio brings the clinical precision and curated atmosphere of a high-end boutique directly to your location.
            </p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 pt-8">
              <div class="space-y-3">
                <h4 class="font-label text-[10px] uppercase tracking-widest text-flt-cream">Medical Grade</h4>
                <p class="font-body text-sm text-flt-muted/60 leading-relaxed">Fully licensed and hospital-grade sterilization standards in a mobile format.</p>
              </div>
              <div class="space-y-3">
                <h4 class="font-label text-[10px] uppercase tracking-widest text-flt-cream">Total Privacy</h4>
                <p class="font-body text-sm text-flt-muted/60 leading-relaxed">One-on-one sessions in a climate-controlled, sound-dampened private sanctuary.</p>
              </div>
              <div class="space-y-3">
                <h4 class="font-label text-[10px] uppercase tracking-widest text-flt-cream">Climate Controlled</h4>
                <p class="font-body text-sm text-flt-muted/60 leading-relaxed">Advanced heating and cooling systems ensure your comfort in any UK season.</p>
              </div>
              <div class="space-y-3">
                <h4 class="font-label text-[10px] uppercase tracking-widest text-flt-cream">UK Wide</h4>
                <p class="font-body text-sm text-flt-muted/60 leading-relaxed">Available for home visits, high-end weddings, and corporate activations nationwide.</p>
              </div>
            </div>
            <div class="pt-12">
              <a href="/mobile-services" class="inline-block border-b border-flt-cream/30 pb-2 font-label text-[10px] uppercase tracking-widest text-flt-cream hover:border-flt-cream transition-all">Explore Mobile Services &rarr;</a>
            </div>
          </div>
        </div>
        <div class="relative order-1 lg:order-2">
          <div class="aspect-square bg-flt-bg border-premium overflow-hidden shadow-2xl skew-y-3 lg:skew-y-6 transform-gpu transition-transform hover:skew-y-0 duration-700">
             <img src="/assets/hero_mobile.png" alt="Mobile Studio Interior" class="w-full h-full object-cover grayscale contrast-125 scale-110" />
          </div>
          <div class="absolute -top-12 -right-12 w-48 h-48 border border-flt-cream/10 rounded-full animate-pulse pointer-events-none"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 3: The Space Boutique -->
  <section class="border-t border-flt-border bg-flt-bg">
    <div
      class="max-w-7xl mx-auto px-4 sm:px-8 lg:px-12 py-24 sm:py-40 grid grid-cols-1 md:grid-cols-12 gap-16 md:gap-20 items-stretch"
    >
      <div class="md:col-span-5 md:sticky md:top-32 h-fit mb-16 md:mb-0">
        <span
          class="font-label text-[9px] uppercase tracking-[0.4rem] text-flt-muted mb-6 block"
          >The Workspace</span
        >
        <h2
          class="font-headline text-fluid-h2 italic tracking-tighter mb-10 cream-text uppercase"
        >
          The Studio <br /> Boutique
        </h2>
        <div class="space-y-6 max-w-sm">
          <p
            class="font-body text-lg sm:text-xl text-flt-muted leading-relaxed"
          >
            Our permanent boutique studio provides a curated environment for
            large-scale illustrative works and intimate appointments.
          </p>
          <p class="font-body text-flt-muted/60">
            A boutique space designed for precision, and the elevation of
            tattooing as a dedicated art form.
          </p>
        </div>
        <div class="mt-12 h-px w-24 bg-flt-border/30"></div>
        <a
          href="/studio"
          class="mt-12 inline-block border border-flt-border px-12 py-5 font-label text-[11px] uppercase tracking-[0.2em] hover:bg-flt-cream hover:text-black transition-all font-bold cream-text shadow-xl"
        >
          View Studio
        </a>
      </div>

      <div
        class="md:col-span-7 grid grid-cols-1 sm:grid-cols-2 gap-8 items-start"
      >
        <div class="space-y-12">
          <div
            class="aspect-[3/4] bg-flt-bg blob-mask-alt contrast-125 transition-all duration-700 flex items-center justify-center border-premium overflow-hidden shadow-2xl"
          >
            <img
              src="/assets/studio_inside.jpg"
              alt="Studio Interior"
              class="w-full h-full object-cover"
            />
          </div>
          <div
            class="aspect-square bg-flt-bg border-premium flex items-center justify-center grayscale opacity-40 hover:opacity-100 transition-all duration-700 overflow-hidden shadow-2xl"
          >
            <img
              src="/assets/archival_tools.png"
              alt="Precision Tools"
              class="w-full h-full object-cover"
            />
          </div>
        </div>
        <div class="pt-0 sm:pt-32 space-y-12">
          <div
            class="aspect-[4/5] bg-flt-bg contrast-150 border-l border-flt-border pl-8 flex items-center justify-center border-premium overflow-hidden shadow-2xl"
          >
            <img
              src="/assets/fineline_work.png"
              alt="Fine-line Mastery"
              class="w-full h-full object-cover"
            />
          </div>
          <blockquote
            class="p-10 border border-flt-border italic font-headline text-2xl sm:text-3xl text-flt-muted/60 leading-tight bg-black/40 uppercase tracking-tighter font-black shadow-2xl"
          >
            "Dedicated to the art of lasting memories."
          </blockquote>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 4: Bespoke Gift Cards -->
  <section class="border-t border-flt-border bg-flt-bg overflow-hidden relative">
     <div class="max-w-7xl mx-auto px-4 sm:px-8 lg:px-12 py-32 sm:py-48 text-center">
        <div class="max-w-3xl mx-auto space-y-12">
           <span class="font-label text-[9px] uppercase tracking-[0.4rem] text-flt-muted block">The Perfect Statement</span>
           <h2 class="font-headline text-fluid-h2 italic tracking-tighter cream-text uppercase">Art, Gifted.</h2>
           <p class="font-body text-xl text-flt-muted leading-relaxed">
              Give the gift of permanent artistry. Our bespoke physical gift cards are a statement of luxury in their own right, delivered in premium packaging.
           </p>
           <div class="pt-12 flex flex-col items-center">
              <!-- Placeholder for final gift card design -->
              <div class="w-full max-w-xl aspect-[1.6/1] bg-flt-border/5 border-premium flex items-center justify-center relative group cursor-pointer overflow-hidden shadow-2xl">
                 <div class="absolute inset-0 bg-flt-cream/5 opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
                 <div class="text-center space-y-4 px-12 z-10 transition-transform group-hover:scale-110 duration-700">
                    <span class="font-label text-[8px] uppercase tracking-[0.4em] text-flt-muted/40 block mb-4">Design Coming Soon</span>
                    <div class="h-px w-12 bg-flt-border/30 mx-auto"></div>
                    <p class="font-headline italic text-2xl cream-text opacity-40 leading-tight">Fun Lovin Tattoo <br/> Bespoke Physical Cards</p>
                 </div>
              </div>
              <a href="/book" class="mt-16 inline-block bg-flt-cream text-black px-16 py-6 font-label text-[11px] uppercase tracking-[0.2em] font-bold shadow-xl hover:bg-white transition-all">
                 Purchase Gift Card
              </a>
           </div>
        </div>
     </div>
  </section>

  <!-- Section 5: Common Queries (FAQ) -->
  <section class="border-t border-flt-border bg-black/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-8 lg:px-12 py-24 sm:py-40">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-20">
        <div class="lg:col-span-5 h-fit lg:sticky lg:top-32">
          <span
            class="font-label text-[9px] uppercase tracking-[0.4rem] text-flt-muted mb-6 block"
            >Common Queries</span
          >
          <h2
            class="font-headline text-fluid-h2 italic tracking-tighter mb-10 cream-text uppercase leading-none"
          >
            Frequently <br /> Asked.
          </h2>
          <p
            class="font-body text-lg text-flt-muted/60 leading-relaxed max-w-sm"
          >
            Answers to the most common questions regarding our studio and mobile
            activations.
          </p>
        </div>

        <div class="lg:col-span-7 space-y-12">
          <div class="space-y-4 border-b border-flt-border/30 pb-12">
            <h3
              class="font-headline text-2xl italic cream-text uppercase tracking-tight mb-4"
            >
              Do tattoos hurt?
            </h3>
            <p class="font-body text-flt-muted leading-relaxed opacity-80">
              Pain is subjective, but yes, there is discomfort. Most clients
              find the process entirely manageable. We focus on a calm,
              professional environment to ensure your comfort throughout the
              session.
            </p>
          </div>

          <div class="space-y-4 border-b border-flt-border/30 pb-12">
            <h3
              class="font-headline text-2xl italic cream-text uppercase tracking-tight mb-4"
            >
              How much does a tattoo cost?
            </h3>
            <p class="font-body text-flt-muted leading-relaxed opacity-80">
              Pricing is bespoke and depends on the size, complexity, and
              placement of the piece. Our studio sessions range from small
              custom works to full-day intensives. Consultations are provided
              for all large projects.
            </p>
          </div>

          <div class="space-y-4 border-b border-flt-border/30 pb-12">
            <h3
              class="font-headline text-2xl italic cream-text uppercase tracking-tight mb-4"
            >
              How do I book an appointment?
            </h3>
            <p class="font-body text-flt-muted leading-relaxed opacity-80">
              All bookings are managed via our online proposal system. Visit our <a
                href="/book"
                class="text-flt-cream underline underline-offset-4"
                >Booking Page</a
              > to start the conversation for a studio or mobile activation.
            </p>
          </div>

          <div class="space-y-4 border-b border-flt-border/30 pb-12">
            <h3
              class="font-headline text-2xl italic cream-text uppercase tracking-tight mb-4"
            >
              What about aftercare?
            </h3>
            <p class="font-body text-flt-muted leading-relaxed opacity-80">
              We provide a comprehensive aftercare kit and detailed instructions
              with every tattoo. Professional care during the healing process is
              critical to the long-term vibrance of your art.
            </p>
          </div>

          <div class="space-y-4">
            <h3
              class="font-headline text-2xl italic cream-text uppercase tracking-tight mb-4"
            >
              Can the mobile studio come to me?
            </h3>
            <p class="font-body text-flt-muted leading-relaxed opacity-80">
              Our mobile unit is available for brand activations, weddings, and
              private events UK-wide. It requires a relatively flat, accessible
              parking space and access to a standard power connection (though we
              are also generator-capable).
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
