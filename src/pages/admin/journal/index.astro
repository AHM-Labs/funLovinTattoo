---
export const prerender = false;
import Layout from '../../../layouts/Layout.astro';
import AdminNav from '../../../components/AdminNav.astro';
import AdminNav from '../../../components/AdminNav.astro';
import { getCollection } from 'astro:content';
import { auth } from "../../../lib/auth";

// SSR: Fetch session
const session = await auth.api.getSession({
    headers: Astro.request.headers
});

if (!session) return Astro.redirect("/admin/login");

const posts = (await getCollection('news')).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title="Journal Manager | Admin">
  <AdminNav currentPath="/admin/journal" userRole={session.user.role} />
  <AdminNav currentPath="/admin/journal" userRole={session.user.role} />
  <div class="max-w-7xl mx-auto px-4 sm:px-8 lg:px-12 py-12">
     <div class="flex justify-between items-end border-b border-flt-border pb-8 mb-12">
        <div>
           <h1 class="font-headline text-5xl italic cream-text uppercase">Journal.</h1>
        </div>
        <a href="/admin/journal/new" class="bg-flt-cream text-black font-label px-10 py-4 uppercase tracking-widest text-[11px] font-bold hover:bg-white transition-all shadow-xl">New Entry</a>
     </div>

     <div class="grid grid-cols-1 gap-6">
        {posts.map(post => (
            <div class="border-premium bg-flt-bg p-8 flex flex-col md:flex-row justify-between items-center gap-8 group shadow-2xl">
                <div class="flex items-center gap-8 flex-1">
                    <div class="w-24 h-24 bg-black border border-flt-border overflow-hidden grayscale group-hover:grayscale-0 transition-all duration-500">
                        {post.data.image ? <img src={post.data.image} class="w-full h-full object-cover" /> : <div class="w-full h-full flex items-center justify-center font-headline italic text-flt-muted/20">MDX</div>}
                    </div>
                    <div>
                        <h2 class="font-headline text-2xl italic cream-text uppercase">{post.data.title}</h2>
                        <p class="font-label text-[9px] uppercase tracking-widest text-flt-muted mt-2">{post.data.date.toLocaleDateString()}</p>
                    </div>
                </div>
                <div class="flex gap-4">
                    <a href={`/admin/journal/edit?id=${post.id}`} class="border border-flt-border text-flt-cream font-label px-6 py-3 uppercase tracking-widest text-[9px] hover:bg-flt-cream hover:text-black transition-all">Edit</a>
                    <button data-id={post.id} class="delete-post border border-red-500/30 text-red-500 font-label px-6 py-3 uppercase tracking-widest text-[9px] hover:bg-red-500 hover:text-white transition-all">Delete</button>
                </div>
            </div>
        ))}
     </div>
  </div>

  <script>
      const deleteButtons = document.querySelectorAll('.delete-post');
      deleteButtons.forEach(btn => {
          btn.addEventListener('click', async (e) => {
              const target = e.currentTarget as HTMLButtonElement;
              const id = target.dataset.id;
              if(!confirm("Are you sure? This will delete the MDX file permanently.")) return;
              
              target.innerText = "Deleting...";
              const res = await fetch(`/api/admin/journal/delete?id=${id}`, { method: 'DELETE' });
              if(res.ok) window.location.reload();
              else (window as any).showModal("Delete Error", "Failed to delete entry.");
          });
      });
  </script>
</Layout>
