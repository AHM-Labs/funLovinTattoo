---
export const prerender = false;
import Layout from '../../../layouts/Layout.astro';
import { auth } from "../../../lib/auth";

const session = await auth.api.getSession({ headers: Astro.request.headers });
if (!session) return Astro.redirect("/admin/login");
---

<Layout title="Add Piece | Admin">
  <div class="max-w-4xl mx-auto px-4 sm:px-8 lg:px-12 py-12">
     <div class="flex justify-between items-end border-b border-flt-ivory-border/20 pb-8 mb-12">
        <div>
           <a href="/admin/gallery" class="font-label text-[10px] uppercase tracking-[0.2rem] text-flt-cream hover:opacity-70 flex items-center gap-2 mb-6">&larr; Gallery</a>
           <h1 class="font-headline text-5xl italic ivory-text uppercase">New Piece.</h1>
        </div>
     </div>

     <form id="upload-form" class="space-y-12">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
            <!-- Upload Area -->
            <div class="space-y-6">
                <div id="drop-zone" class="aspect-square border border-dashed border-flt-ivory-border/20 bg-black/20 flex flex-col items-center justify-center cursor-pointer hover:bg-black/40 transition-colors relative">
                    <input type="file" id="image-input" accept="image/*" class="absolute inset-0 opacity-0 cursor-pointer" required />
                    <div id="preview-container" class="absolute inset-0 hidden pointer-events-none">
                        <img id="preview-img" class="w-full h-full object-cover" />
                        <div class="absolute inset-0 bg-black/40 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                            <span class="text-white font-label text-[10px] uppercase tracking-widest bg-black/60 px-4 py-2">Change Image</span>
                        </div>
                    </div>
                    <div id="upload-prompt" class="text-center p-8">
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-4 text-flt-muted"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                        <p class="font-label text-[9px] uppercase tracking-widest text-flt-muted">Click or drag image to upload</p>
                    </div>
                </div>
                <p class="text-[9px] text-flt-muted/40 italic text-center font-body">Supported: JPG, PNG, WebP (Max 5MB)</p>
            </div>

            <!-- Metadata Area -->
            <div class="space-y-8">
                <div class="space-y-4">
                    <label class="font-label text-[10px] uppercase tracking-widest text-flt-muted block">Alt Text (Required)</label>
                    <input type="text" id="altText" placeholder="e.g. Traditional Blackwork Dagger" required class="w-full bg-[#0d0d0d] border border-flt-ivory-border/20 p-4 text-white font-body focus:border-flt-cream outline-none transition-colors" />
                    <p class="text-[9px] text-flt-muted/40 italic">Used for SEO and accessibility.</p>
                </div>

                <div class="space-y-4">
                    <label class="font-label text-[10px] uppercase tracking-widest text-flt-muted block">Description (Optional)</label>
                    <textarea id="description" placeholder="Optional details about the piece..." class="w-full bg-[#0d0d0d] border border-flt-ivory-border/20 p-4 text-white font-body focus:border-flt-cream outline-none transition-colors h-32 resize-none"></textarea>
                </div>

                <button type="submit" id="submit-btn" class="w-full bg-white text-black font-label py-5 uppercase tracking-[0.2em] font-bold text-xs hover:bg-flt-cream transition-all shadow-xl mt-8">Upload Piece</button>
            </div>
        </div>
     </form>
  </div>

  <script>
      const form = document.getElementById('upload-form') as HTMLFormElement;
      const fileInput = document.getElementById('image-input') as HTMLInputElement;
      const previewContainer = document.getElementById('preview-container');
      const previewImg = document.getElementById('preview-img') as HTMLImageElement;
      const uploadPrompt = document.getElementById('upload-prompt');
      const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

      fileInput?.addEventListener('change', (e) => {
          const file = fileInput.files?.[0];
          if (file) {
              const reader = new FileReader();
              reader.onload = (e) => {
                  if (previewImg && previewContainer && uploadPrompt) {
                      previewImg.src = e.target?.result as string;
                      previewContainer.classList.remove('hidden');
                      uploadPrompt.classList.add('hidden');
                  }
              };
              reader.readAsDataURL(file);
          }
      });

      form?.addEventListener('submit', async (e) => {
          e.preventDefault();
          
          const formData = new FormData();
          const file = fileInput.files?.[0];
          const altText = (document.getElementById('altText') as HTMLInputElement).value;
          const description = (document.getElementById('description') as HTMLTextAreaElement).value;

          if (!file) return;

          submitBtn.innerText = "Uploading...";
          submitBtn.disabled = true;

          formData.append('image', file);
          formData.append('altText', altText);
          formData.append('description', description);

          try {
              const res = await fetch("/api/admin/gallery/upload", {
                  method: "POST",
                  body: formData
              });

              if (res.ok) {
                  (window as any).showModal("Success", "New piece added to your gallery!");
                  setTimeout(() => window.location.href = "/admin/gallery", 1500);
              } else {
                  const data = await res.json();
                  (window as any).showModal("Upload Failed", data.error || "Check your network.");
                  submitBtn.innerText = "Upload Piece";
                  submitBtn.disabled = false;
              }
          } catch (e) {
              (window as any).showModal("Network Error", "Unable to reach server.");
              submitBtn.innerText = "Upload Piece";
              submitBtn.disabled = false;
          }
      });
  </script>
</Layout>
