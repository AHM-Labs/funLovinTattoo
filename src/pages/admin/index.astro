---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { auth } from "../../lib/auth";

// Server-side session check (middleware handles redirection, but we can get user data here)
const session = await auth.api.getSession({
    headers: Astro.request.headers
});

const user = session?.user;

if (user?.requiresPasswordReset) {
    return Astro.redirect("/admin/reset-password");
}
---

<Layout title="Admin Dashboard | Professional Artistry">
  <div class="max-w-7xl mx-auto px-4 sm:px-8 lg:px-12 py-12">
     <div class="flex justify-between items-end border-b border-flt-ivory-border/20 pb-8 mb-12">
        <div>
           <span class="font-label text-[10px] uppercase tracking-[0.4rem] text-flt-muted block mb-2">Control Center</span>
           <h1 class="font-headline text-5xl italic ivory-text uppercase">Welcome, {user?.name || 'Artist'}.</h1>
        </div>
        <div class="flex gap-4">
           <button id="logout-btn" class="bg-flt-cream text-black font-label px-6 py-3 uppercase tracking-widest text-[10px] font-bold hover:bg-white transition-colors shadow-lg">Sign Out</button>
        </div>
     </div>

     <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Quick Actions / Status -->
        <div class="lg:col-span-1 space-y-8">
           <div class="border-premium bg-[#111] p-8">
              <h2 class="font-headline text-2xl italic ivory-text uppercase mb-6 border-b border-flt-ivory-border/10 pb-4">Today's Setup</h2>
              <form id="location-form" class="space-y-4">
                 <div>
                    <label class="font-label text-[9px] uppercase tracking-widest text-flt-muted block mb-2">Mobile Van Location</label>
                    <input type="text" id="van-location" placeholder="e.g. Canalside Ind. Estate" class="w-full bg-[#0d0d0d] border border-flt-ivory-border/20 p-4 text-white font-body focus:border-flt-cream outline-none transition-colors" />
                 </div>
                 <button type="submit" class="w-full border border-flt-cream/30 text-flt-cream font-label py-3 uppercase tracking-widest text-[10px] hover:bg-flt-cream hover:text-black transition-colors">Update Location</button>
              </form>
           </div>
        </div>

        <!-- Main Dashboard Area -->
        <div class="lg:col-span-2 space-y-8">
           <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
              <a href="/admin/bookings" class="border-premium bg-flt-border/5 p-8 hover:bg-[#111] transition-colors group">
                 <h3 class="font-headline text-3xl italic ivory-text uppercase mb-2 group-hover:text-white">Inquiries</h3>
                 <p class="font-label text-[10px] uppercase tracking-widest text-flt-muted">Manage Bookings &rarr;</p>
              </a>
              <a href="/admin/journal" class="border-premium bg-flt-border/5 p-8 hover:bg-[#111] transition-colors group">
                 <h3 class="font-headline text-3xl italic ivory-text uppercase mb-2 group-hover:text-white">Journal</h3>
                 <p class="font-label text-[10px] uppercase tracking-widest text-flt-muted">Write & Edit &rarr;</p>
              </a>
              <a href="/admin/team" class="border-premium bg-flt-border/5 p-8 hover:bg-[#111] transition-colors group">
                 <h3 class="font-headline text-3xl italic ivory-text uppercase mb-2 group-hover:text-white">Team</h3>
                 <p class="font-label text-[10px] uppercase tracking-widest text-flt-muted">Manage Team &rarr;</p>
              </a>
           </div>
        </div>
     </div>
  </div>

  <script>
    import { authClient } from "../../lib/auth-client";

    // Passkey Management
    async function loadPasskeys() {
        const listEl = document.getElementById("passkeys-list");
        if (!listEl) return;
        
        const { data, error } = await authClient.passkey.listUserPasskeys();
        if (error || !data) {
            listEl.innerHTML = `<p class="text-red-500 text-[10px]">Error loading passkeys</p>`;
            return;
        }

        if (data.length === 0) {
            listEl.innerHTML = `<p class="text-flt-muted text-[10px] italic">No biometric devices registered.</p>`;
            return;
        }

        listEl.innerHTML = data.map(pk => `
            <div class="flex justify-between items-center bg-black/40 p-3 border border-flt-ivory-border/5">
                <div>
                   <p class="font-label text-[10px] text-white uppercase tracking-wider">${pk.name || 'Passkey Device'}</p>
                   <p class="text-[8px] text-flt-muted uppercase mt-1">Added ${new Date(pk.createdAt).toLocaleDateString()}</p>
                </div>
                <button class="delete-pk-btn text-red-500/50 hover:text-red-500 font-label text-[8px] uppercase tracking-widest transition-colors" data-id="${pk.id}">Remove</button>
            </div>
        `).join('');

        document.querySelectorAll(".delete-pk-btn").forEach(btn => {
            btn.addEventListener("click", async (e) => {
                const id = (e.target as HTMLElement).dataset.id;
                if (!id || !confirm("Remove this device secondary access?")) return;
                const { error } = await authClient.passkey.deletePasskey({ id });
                if (error) alert(error.message);
                else loadPasskeys();
            });
        });
    }

    loadPasskeys();

    document.getElementById("add-passkey-btn-dash")?.addEventListener("click", async () => {
       const name = prompt("Enter a name for this device (e.g. iPhone 15, MacBook Pro):");
       const { error } = await authClient.passkey.addPasskey({ name: name || undefined });
       if (error) {
           alert("Failed to add passkey: " + error.message);
       } else {
           alert("Passkey successfully registered!");
           loadPasskeys();
       }
    });

    document.getElementById("location-form")?.addEventListener("submit", async (e) => {
       e.preventDefault();
       const location = (document.getElementById("van-location") as HTMLInputElement).value;
       const form = e.target as HTMLFormElement;
       const submitBtn = form.querySelector('button');
       if(submitBtn) submitBtn.textContent = "Updating...";
       
       try {
           const res = await fetch("/api/settings", {
               method: "POST",
               body: JSON.stringify({ key: "van_location", value: location })
           });
           if (res.ok) alert("Location updated successfully!");
           else alert("Failed to update location.");
       } catch (e) {
           alert("Error updating location.");
       }
       if(submitBtn) submitBtn.textContent = "Update Location";
    });

    document.getElementById("logout-btn")?.addEventListener("click", async () => {
       await authClient.signOut();
       window.location.href = "/admin/login";
    });
  </script>
</Layout>
