---
export const prerender = false;
import Layout from "../../../layouts/Layout.astro";
import AdminNav from "../../../components/AdminNav.astro";
import { auth } from "../../../lib/auth";
import { giftCardDb } from "../../../db/giftcards/db";
import { giftCards } from "../../../db/giftcards/schema";
import { desc } from "drizzle-orm";

const session = await auth.api.getSession({ headers: Astro.request.headers });
if (!session) return Astro.redirect("/login");
const { user } = session;

const allGiftCards = await giftCardDb.select().from(giftCards).orderBy(desc(giftCards.createdAt));
const totalLiability = allGiftCards.reduce((acc, card) => acc + card.currentBalance, 0);
---

<Layout title="Gift Card Management | Admin">
  <AdminNav currentPath="/admin/gift-cards" userRole={user.role} />
  
  <div class="max-w-7xl mx-auto px-4 sm:px-8 lg:px-12 py-12">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end border-b border-flt-border pb-8 mb-12 gap-8">
      <div>
        <span class="font-label text-[10px] uppercase tracking-[0.4rem] text-flt-muted mb-4 block underline decoration-flt-cream/30 underline-offset-8">Financial Operations</span>
        <h1 class="font-headline text-5xl italic cream-text uppercase">Gift Cards.</h1>
      </div>
      
      <div class="flex gap-12">
        <div class="text-right">
          <p class="font-label text-[8px] uppercase tracking-widest text-flt-muted mb-1">Total Liability</p>
          <p class="font-headline text-3xl cream-text">£{(totalLiability / 100).toFixed(2)}</p>
        </div>
        <button id="open-create-modal" class="bg-flt-cream text-black px-10 py-4 font-label text-[10px] font-bold uppercase tracking-widest hover:bg-white transition-all shadow-xl">
          Issue New Card
        </button>
      </div>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="border-b border-flt-border/30">
            <th class="py-6 font-label text-[10px] uppercase tracking-widest text-flt-muted font-bold">Card ID</th>
            <th class="py-6 font-label text-[10px] uppercase tracking-widest text-flt-muted font-bold">PIN</th>
            <th class="py-6 font-label text-[10px] uppercase tracking-widest text-flt-muted font-bold">Balance</th>
            <th class="py-6 font-label text-[10px] uppercase tracking-widest text-flt-muted font-bold">Status</th>
            <th class="py-6 font-label text-[10px] uppercase tracking-widest text-flt-muted font-bold">Created</th>
            <th class="py-6 font-label text-[10px] uppercase tracking-widest text-flt-muted font-bold text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-flt-border/10">
          {allGiftCards.length === 0 ? (
            <tr>
              <td colspan="6" class="py-20 text-center font-body text-flt-muted italic opacity-50">No gift cards issued yet.</td>
            </tr>
          ) : (
            allGiftCards.map(card => (
              <tr class="group hover:bg-white/[0.02] transition-colors">
                <td class="py-6 font-label text-xs tracking-widest cream-text font-bold">{card.id}</td>
                <td class="py-6 font-body text-xs text-flt-muted font-mono">{card.pin}</td>
                <td class="py-6 font-label text-xs cream-text">£{(card.currentBalance / 100).toFixed(2)}</td>
                <td class="py-6">
                  <span class={`px-3 py-1 text-[8px] uppercase tracking-widest font-bold ${card.status === 'active' ? 'bg-green-500/10 text-green-500 border border-green-500/20' : 'bg-red-500/10 text-red-500 border border-red-500/20'}`}>
                    {card.status}
                  </span>
                </td>
                <td class="py-6 font-body text-[10px] text-flt-muted/60">{new Date(card.createdAt).toLocaleDateString()}</td>
                <td class="py-6 text-right">
                  <a href={`/admin/gift-cards/${card.id}`} class="font-label text-[10px] uppercase tracking-widest text-flt-cream border border-flt-cream/30 px-4 py-2 hover:bg-flt-cream hover:text-black transition-all">Manage</a>
                </td>
              </tr>
            ))
          )}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Create Modal -->
  <div id="create-modal" class="fixed inset-0 z-50 flex items-center justify-center p-6 bg-black/90 backdrop-blur-sm hidden opacity-0 transition-all duration-300">
    <div class="bg-flt-bg border-premium p-10 max-w-md w-full shadow-2xl transform scale-95 transition-all duration-300" id="modal-content">
      <h2 class="font-headline text-3xl italic cream-text uppercase mb-6 border-b border-flt-border pb-4">Issue Card</h2>
      <p class="font-body text-xs text-flt-muted mb-8 leading-relaxed">Enter the starting balance. The Card ID and PIN will be automatically generated upon creation.</p>
      
      <form id="create-form" class="space-y-8">
        <div class="space-y-3">
          <label for="amount" class="font-label text-[10px] uppercase tracking-widest text-flt-cream block">Amount (GBP)</label>
          <div class="relative">
            <span class="absolute left-5 top-1/2 -translate-y-1/2 text-flt-muted font-body">£</span>
            <input type="number" id="amount" name="amount" step="1" min="1" required class="w-full bg-black/40 border border-flt-border p-5 pl-10 text-flt-cream font-body focus:border-flt-cream outline-none transition-all" placeholder="50" />
          </div>
        </div>
        
        <div class="flex gap-4 pt-4">
          <button type="button" id="close-modal" class="flex-1 border border-flt-border text-flt-muted font-label py-4 uppercase tracking-widest text-[10px] hover:bg-white/5 transition-colors">Cancel</button>
          <button type="submit" id="submit-btn" class="flex-1 bg-flt-cream text-black font-label py-4 uppercase tracking-widest text-[10px] font-bold hover:bg-white transition-all">Generate & Save</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    const modal = document.getElementById('create-modal');
    const modalContent = document.getElementById('modal-content');
    const openBtn = document.getElementById('open-create-modal');
    const closeBtn = document.getElementById('close-modal');
    const createForm = document.getElementById('create-form') as HTMLFormElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

    function openModal() {
      modal?.classList.remove('hidden');
      setTimeout(() => {
        modal?.classList.add('opacity-100');
        modalContent?.classList.remove('scale-95');
        modalContent?.classList.add('scale-100');
      }, 10);
    }

    function closeModal() {
      modal?.classList.remove('opacity-100');
      modalContent?.classList.add('scale-95');
      modalContent?.classList.remove('scale-100');
      setTimeout(() => modal?.classList.add('hidden'), 300);
    }

    openBtn?.addEventListener('click', openModal);
    closeBtn?.addEventListener('click', closeModal);
    
    // Close on background click
    modal?.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });

    createForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(createForm);
      const amount = parseInt(formData.get('amount') as string);
      
      if (isNaN(amount) || amount <= 0) return alert('Please enter a valid amount');
      
      submitBtn.disabled = true;
      submitBtn.innerText = 'Creating...';
      
      try {
        const res = await fetch('/api/admin/gift-cards/create', {
          method: 'POST',
          body: JSON.stringify({ amount }),
          headers: { 'Content-Type': 'application/json' }
        });
        
        if (res.ok) {
          window.location.reload();
        } else {
          const err = await res.json();
          alert(err.error || 'Failed to create gift card');
          submitBtn.disabled = false;
          submitBtn.innerText = 'Generate & Save';
        }
      } catch (err) {
        alert('Network error. Please try again.');
        submitBtn.disabled = false;
        submitBtn.innerText = 'Generate & Save';
      }
    });
  </script>
</Layout>
