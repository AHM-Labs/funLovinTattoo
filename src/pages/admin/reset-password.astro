---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { auth } from "../../lib/auth";

// Check if user is logged in but needs reset
const session = await auth.api.getSession({
    headers: Astro.request.headers
});

if (!session) return Astro.redirect("/admin/login");
if (!session.user.requiresPasswordReset) return Astro.redirect("/admin");

---

<Layout title="Reset Password | Admin">
  <div class="min-h-screen flex items-center justify-center p-6 bg-[#0a0a0a]">
    <div class="max-w-md w-full border border-flt-ivory-border/20 p-12 bg-black/40 backdrop-blur-xl shadow-2xl">
      <h1 class="font-headline text-5xl italic ivory-text uppercase mb-8 text-center">Security <br/> Update.</h1>
      
      <p class="font-body text-flt-muted text-center mb-10 text-sm leading-relaxed">
        This is your first login with a temporary password. Please establish a new secure password to continue.
      </p>

      <form id="reset-form" class="space-y-6">
        <div class="space-y-2">
          <label class="font-label text-[10px] uppercase tracking-widest text-flt-muted block">Current (Temporary) Password</label>
          <input type="password" id="current" required class="w-full bg-[#0d0d0d] border border-flt-ivory-border/20 p-4 text-white font-body focus:border-flt-cream outline-none transition-colors" />
        </div>
        <div class="space-y-2">
          <label class="font-label text-[10px] uppercase tracking-widest text-flt-muted block">New Password</label>
          <input type="password" id="password" required class="w-full bg-[#0d0d0d] border border-flt-ivory-border/20 p-4 text-white font-body focus:border-flt-cream outline-none transition-colors" />
        </div>
        <div class="space-y-2">
          <label class="font-label text-[10px] uppercase tracking-widest text-flt-muted block">Confirm New Password</label>
          <input type="password" id="confirm" required class="w-full bg-[#0d0d0d] border border-flt-ivory-border/20 p-4 text-white font-body focus:border-flt-cream outline-none transition-colors" />
        </div>
        <button type="submit" class="w-full bg-white text-black font-label py-5 uppercase tracking-[0.2em] font-bold text-xs hover:bg-flt-cream transition-all shadow-xl mt-8">Register Password</button>
      </form>

      <div id="passkey-section" class="mt-12 pt-12 border-t border-flt-ivory-border/10 hidden">
          <p class="font-label text-[9px] uppercase tracking-widest text-flt-cream mb-4 text-center">Step 2: Passwordless Access</p>
          <button id="add-passkey-btn" class="w-full border border-flt-cream/40 text-flt-cream font-label py-4 uppercase tracking-widest text-[10px] hover:bg-flt-cream hover:text-black transition-all">Add This Device Passkey</button>
          <a href="/admin" class="block text-center mt-6 font-label text-[9px] uppercase tracking-widest text-flt-muted/40 hover:text-flt-muted underline">Skip for now</a>
      </div>
    </div>
  </div>

  <script>
    import { authClient } from "../../lib/auth-client";

    const form = document.getElementById('reset-form') as HTMLFormElement;
    const passkeySection = document.getElementById('passkey-section');
    const submitBtn = form.querySelector('button');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const currentPassword = (document.getElementById('current') as HTMLInputElement).value;
      const password = (document.getElementById('password') as HTMLInputElement).value;
      const confirm = (document.getElementById('confirm') as HTMLInputElement).value;

      if (password !== confirm) {
        (window as any).showModal("Validation Error", "Passwords do not match.");
        return;
      }

      if(submitBtn) submitBtn.textContent = "Updating...";

      const { error } = await authClient.changePassword({
          currentPassword: currentPassword,
          newPassword: password,
          revokeOtherSessions: false // Keep session alive to finish onboarding
      });

      if (error) {
        (window as any).showModal("Update Failed", "Failed to update password: " + error.message);
        if(submitBtn) submitBtn.textContent = "Register Password";
      } else {
        // Now update the flag
        const resetRes = await fetch("/api/admin/users/complete-reset", { method: "POST" });
        if (!resetRes.ok) {
            console.error("Failed to clear reset flag:", await resetRes.text());
        }
        
        // Refresh session
        await authClient.getSession();
        
        form.classList.add('hidden');
        passkeySection?.classList.remove('hidden');
        if(submitBtn) submitBtn.textContent = "Success";
      }
    });

    document.getElementById('add-passkey-btn')?.addEventListener('click', async () => {
        const { error } = await authClient.passkey.addPasskey();
        if (error) {
            (window as any).showModal("Passkey Error", error.message);
        } else {
            // Ensure flag is cleared if they skipped the password step or just for safety
            await fetch("/api/admin/users/complete-reset", { method: "POST" });
            // Refresh session info in client
            await authClient.getSession();
            
            alert("Passkey added! Welcome back.");
            window.location.href = "/admin";
        }
    });
  </script>
</Layout>
