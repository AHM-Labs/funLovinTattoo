---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import AdminNav from '../../components/AdminNav.astro';
import { db } from "../../db";
import { bookings } from "../../db/schema";
import { desc } from "drizzle-orm";

// SSR: Fetch directly from database on component load
const allBookings = await db.select().from(bookings).orderBy(desc(bookings.createdAt));
---

<Layout title="Booking Inquiries | Admin">
  <AdminNav currentPath="/admin/bookings" />
  <div class="max-w-7xl mx-auto px-4 sm:px-8 lg:px-12 py-12">
     <div class="flex justify-between items-end border-b border-flt-ivory-border/20 pb-8 mb-12">
        <div>
           <a href="/admin" class="font-label text-[10px] uppercase tracking-[0.2rem] text-flt-cream hover:opacity-70 flex items-center gap-2 mb-6">&larr; Dashboard</a>
           <h1 class="font-headline text-5xl italic ivory-text uppercase">Inquiries.</h1>
        </div>
     </div>

     <div class="space-y-6">
        {allBookings.length === 0 ? (
            <div class="p-12 border-premium bg-[#111] text-center text-flt-muted font-body">
                No inquiries found yet.
            </div>
        ) : (
            allBookings.map((booking) => (
                <div class="border-premium bg-[#0d0d0d] p-8 lg:p-10 flex flex-col md:flex-row gap-8 justify-between items-start">
                    <div class="space-y-4">
                        <div class="flex items-center gap-4">
                            <span class={`font-label text-[9px] uppercase tracking-widest px-3 py-1 ${booking.status === 'pending' ? 'bg-yellow-500/20 text-yellow-500 border border-yellow-500/30' : booking.status === 'accepted' ? 'bg-green-500/20 text-green-500 border border-green-500/30' : 'bg-red-500/20 text-red-500 border border-red-500/30'}`}>
                                {booking.status}
                            </span>
                            <span class="font-label text-[10px] uppercase tracking-widest text-white border-b border-white pb-0.5">{booking.type}</span>
                        </div>
                        <div>
                            <h2 class="font-headline text-3xl italic ivory-text">{booking.name}</h2>
                            <p class="font-label text-[11px] text-flt-muted/60 mt-2">{booking.email} • {booking.phone || 'No phone'}</p>
                        </div>
                        <p class="font-body text-flt-muted leading-relaxed max-w-2xl bg-[#111] p-6 border border-flt-ivory-border/10 mt-4 rounded-sm">"{booking.details}"</p>
                        <p class="font-label text-[9px] text-flt-muted/40 uppercase tracking-widest mt-2">Requested Date: {booking.date || 'N/A'}</p>
                    </div>
                    {booking.status === 'pending' && (
                        <div class="flex gap-4 md:flex-col lg:flex-row w-full md:w-auto">
                            <button data-id={booking.id} data-action="accept" class="booking-action flex-1 md:flex-none border border-green-500/50 text-green-500 hover:bg-green-500 hover:text-black font-label text-[10px] uppercase tracking-widest px-8 py-4 transition-all">Accept</button>
                            <button data-id={booking.id} data-action="decline" class="booking-action flex-1 md:flex-none border border-red-500/50 text-red-500 hover:bg-red-500 hover:text-white font-label text-[10px] uppercase tracking-widest px-8 py-4 transition-all">Decline</button>
                        </div>
                    )}
                </div>
            ))
        )}
     </div>
  </div>

  <script>
      const buttons = document.querySelectorAll('.booking-action');
      buttons.forEach(btn => {
          btn.addEventListener('click', async (e) => {
              const target = e.currentTarget as HTMLButtonElement;
              const id = target.dataset.id;
              const action = target.dataset.action;
              
              if(!confirm(`Are you sure you want to ${action} this booking? This will send an email to the client.`)) return;

              const originalText = target.innerText;
              target.innerText = "Processing...";

              try {
                  const res = await fetch("/api/admin/bookings/action", {
                      method: "POST",
                      body: JSON.stringify({ id, action })
                  });
                  if (res.ok) {
                      window.location.reload();
                  } else {
                      const error = await res.json();
                      (window as any).showModal("Action Failed", error.error);
                      target.innerText = originalText;
                  }
              } catch(e) {
                  (window as any).showModal("Network Error", "Unable to reach server.");
                  target.innerText = originalText;
              }
          });
      });
  </script>
</Layout>
