---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Wedding Tattoos | The Ultimate Party Favor">
  <div class="max-w-7xl mx-auto px-4 sm:px-8 lg:px-12 py-24">
    <div class="text-center mb-32">
      <span class="font-label text-[10px] uppercase tracking-[0.4em] text-flt-muted mb-6 inline-block">Bespoke Celebrations</span>
      <h1 class="font-headline text-7xl md:text-[9.5rem] italic tracking-tighter ivory-text font-black uppercase leading-[0.8]">Love <br/> & Ink.</h1>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-20 items-center mb-32">
      <div class="lg:col-span-7">
        <div class="aspect-video bg-flt-border/5 border-premium overflow-hidden group">
          <img 
            src="/assets/wedding_hero_bespoke.png" 
            alt="Wedding Tattoo Activation" 
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-[4s]" 
          />
        </div>
      </div>
      <div class="lg:col-span-5 space-y-12">
        <h2 class="font-headline text-5xl italic ivory-text leading-tight uppercase">The Ultimate <br/> Party Favor.</h2>
        <p class="font-body text-xl text-flt-muted leading-relaxed">
          Elevate your wedding with a curated live tattoo studio. We bring the professional studio experience to your venue, offering custom-designed flashes that your guests will cherish forever.
        </p>
        <ul class="space-y-6 font-label text-[11px] uppercase tracking-widest text-flt-muted border-t border-flt-ivory-border/20 pt-8">
          <li class="flex items-center gap-4"><span class="text-flt-cream text-lg">†</span> Custom Flash Sheets for the Couple</li>
          <li class="flex items-center gap-4"><span class="text-flt-cream text-lg">†</span> Full Mobile Studio Setup</li>
          <li class="flex items-center gap-4"><span class="text-flt-cream text-lg">†</span> Health & Safety Certified</li>
          <li class="flex items-center gap-4"><span class="text-flt-cream text-lg">†</span> Professional Artist Collective</li>
        </ul>
      </div>
    </div>

    <section class="py-24 border-t border-flt-ivory-border/10">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <div class="p-10 border-premium bg-[#111] space-y-6">
          <h3 class="font-headline text-3xl italic ivory-text uppercase">Bespoke</h3>
          <p class="font-body text-flt-muted opacity-70">Personalized flash designs tailored to your wedding theme and story.</p>
        </div>
        <div class="p-10 border-premium bg-[#111] space-y-6">
          <h3 class="font-headline text-3xl italic ivory-text uppercase">Elegant</h3>
          <p class="font-body text-flt-muted opacity-70">Unobtrusive, professional setup that blends seamlessly with luxury venues.</p>
        </div>
        <div class="p-10 border-premium bg-[#111] space-y-6">
          <h3 class="font-headline text-3xl italic ivory-text uppercase">Legendary</h3>
          <p class="font-body text-flt-muted opacity-70">An unforgettable experience that guests will talk about for years.</p>
        </div>
      </div>
    </section>

    <PricingSection 
        type="mobile" 
        categoryName="Weddings (Van)" 
        title="Wedding Pricing." 
        description="Premium mobile activation for your special day. All packages include the full mobile studio and a dedicated artist."
    />

    <div class="mt-32 text-center bg-flt-cream py-32 px-4 shadow-2xl">
      <h2 class="font-headline text-6xl md:text-8xl italic text-black uppercase mb-12 tracking-tighter">Secure Your Date.</h2>
      <a href="/book?type=wedding" class="inline-block border-2 border-black px-16 py-6 font-label text-xs uppercase tracking-[0.3em] font-black hover:bg-black hover:text-white transition-all">Request Proposal</a>
    </div>
  </div>
</Layout>
