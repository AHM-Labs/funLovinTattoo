---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import Gallery from '../../components/Gallery.astro';
import { db } from "../../db";
import { user as userTable, gallery as galleryTable } from "../../db/schema";
import { eq } from "drizzle-orm";

const { slug } = Astro.params;

// Fetch artist by handle
const artistResults = await db.select().from(userTable).where(eq(userTable.handle, slug as string)).limit(1);
const artist = artistResults[0];

if (!artist) return Astro.redirect('/404');

// Fetch gallery images
const portfolio = await db.select().from(galleryTable).where(eq(galleryTable.artistId, artist.id));
---

<Layout title={`${artist.name} | Resident Artist`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-8 lg:px-12 py-24">
    <div class="mb-16">
      <a href="/artists" class="font-label text-[10px] uppercase tracking-widest text-flt-muted hover:cream-text transition-colors border-b border-flt-border pb-1">&larr; Back to Artists</a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-20 items-start">
      <div class="lg:col-span-5 lg:sticky lg:top-10">
        <div class="aspect-[3/4] bg-flt-bg/5 mb-12 border-premium overflow-hidden grayscale contrast-125 shadow-2xl">
          {artist.image ? (
              <img src={artist.image} alt={artist.name} class="w-full h-full object-cover" />
          ) : (
                <div class="w-full h-full flex items-center justify-center bg-black/40">
                    <span class="font-headline text-3xl italic text-flt-muted/30 uppercase tracking-tighter">Coming Soon</span>
                </div>
          )}
        </div>
        <h1 class="font-headline text-6xl md:text-8xl italic cream-text leading-[0.9] tracking-tighter mb-8 uppercase">{artist.name}</h1>
        <p class="font-label text-xs uppercase tracking-[0.4em] text-flt-muted mb-8">{artist.role} — {artist.specialty}</p>
        <div class="h-px w-24 bg-flt-border/30 mb-8"></div>
        <div class="prose prose-invert prose-cream font-body text-flt-muted leading-relaxed italic text-lg whitespace-pre-line" set:html={artist.bio}>
        </div>
      </div>

      <div class="lg:col-span-1 hidden lg:block h-full border-r border-flt-border"></div>

      <div class="lg:col-span-6 space-y-24 pt-12 lg:pt-0">
        <section>
          <span class="font-label text-[9px] uppercase tracking-[0.5em] text-flt-muted mb-8 block">Selected Work</span>
          <Gallery images={portfolio.map(img => ({ src: img.url, alt: img.altText }))} />
          {portfolio.length === 0 && (
             <p class="font-body text-xs text-flt-muted italic opacity-50">Portfolio pieces coming soon.</p>
          )}
        </section>

        <section class="p-12 border-premium bg-flt-bg shadow-2xl">
          <h3 class="font-headline text-3xl font-black italic mb-8 border-b border-flt-border pb-4 uppercase cream-text">Philosophy</h3>
          <div class="prose prose-invert prose-cream font-body text-flt-muted leading-relaxed opacity-80" set:html={artist.philosophy || artist.bio}>
          </div>
          <a href="/book" class="mt-12 block bg-flt-cream text-black text-center py-5 font-label text-[11px] uppercase tracking-widest font-bold hover:bg-white transition-all shadow-xl">Inquire with {artist.name.split(' ')[0]}</a>
        </section>
      </div>
    </div>
  </div>
</Layout>
