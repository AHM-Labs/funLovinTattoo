---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts: CollectionEntry<'news'>[] = (await getCollection('news')).sort(
  (a: CollectionEntry<'news'>, b: CollectionEntry<'news'>) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title="Journal | Professional Artistry">
  <div class="max-w-7xl mx-auto px-4 sm:px-8 lg:px-12 py-24">
    <div class="text-center mb-32">
      <span class="font-label text-[10px] uppercase tracking-[0.4em] text-flt-muted mb-6 inline-block">The Portfolio</span>
      <h1 class="font-headline text-7xl md:text-[9rem] italic tracking-tighter ivory-text font-black uppercase">Journal.</h1>
    </div>

    <div class="space-y-12">
      {posts.map(post => (
        <article class="group border-b border-flt-ivory-border/10 pb-12">
          <a href={`/news/${post.id}`} class="grid grid-cols-1 md:grid-cols-12 gap-8 items-center pt-8">
            <div class="md:col-span-3 aspect-[4/3] bg-flt-border/5 overflow-hidden border-premium grayscale group-hover:grayscale-0 transition-all duration-700">
               {post.data.image ? (
                 <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-1000" />
               ) : (
                 <div class="w-full h-full flex items-center justify-center font-headline italic text-flt-muted/20 tracking-widest uppercase">Entry.{post.id.slice(0, 2)}</div>
               )}
            </div>
            <div class="md:col-span-1 hidden md:block">
               <span class="font-label text-[10px] text-flt-muted/40 rotate-90 block tracking-widest uppercase">
                 {post.data.date.toLocaleDateString('en-GB', { day: '2-digit', month: '2-digit' })}
               </span>
            </div>
            <div class="md:col-span-8">
              <h2 class="font-headline text-4xl md:text-5xl italic ivory-text group-hover:cream-text transition-colors leading-tight mb-4 uppercase tracking-tighter">
                {post.data.title}
              </h2>
              <p class="font-body text-flt-muted max-w-2xl text-sm leading-relaxed mb-6">
                {post.data.description}
              </p>
              <span class="font-label text-[9px] uppercase tracking-[0.3em] ivory-text border-b border-flt-ivory-border/30 pb-1 group-hover:border-flt-ivory transition-all">Read Entry &rarr;</span>
            </div>
          </a>
        </article>
      ))}
      
      {posts.length === 0 && (
        <div class="text-center py-32 border-t border-b border-dashed border-flt-border/20 text-flt-muted/40">
          <p class="font-headline italic text-2xl">The archive is silent for now.</p>
        </div>
      )}
    </div>
  </div>
</Layout>
